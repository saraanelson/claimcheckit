# ClaimCheck - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# Vercel Supabase integration key (preferred):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key
# Fallback for manual setup:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Tavily (used by API route and Supabase Edge Function for web search)
TAVILY_API_KEY=your_tavily_api_key

# Anthropic (used by API route and Supabase Edge Function for Claude-powered claim analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key
